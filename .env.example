# Copy this file to .env and fill in your values
# Never commit .env — it contains secrets

# URL of your running FastAPI backend (ngrok tunnel, Kaggle, or your own server)
VITE_API_URL=https://your-ngrok-url.ngrok-free.app

# About Model tab persona: 'dl' (deep learning focus) or 'cv' (computer vision focus)
VITE_ABOUT_MODE=dl
